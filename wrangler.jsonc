{
  "name": "listo",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    // SPA fallback: serve index.html for unknown paths (/list/:id, /join/:code…).
    // Replaces the old Pages `_redirects` catch-all, which Workers rejects
    // as an infinite loop (error 100324).
    "not_found_handling": "single-page-application"
  }
}
