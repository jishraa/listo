{
  "name": "listo",
  "compatibility_date": "2026-07-01",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    // SPA fallback: serve index.html for unknown paths (/list/:id, /join/:code…).
    "not_found_handling": "single-page-application",
    // API routes bypass asset serving and hit the Worker script
    "run_worker_first": ["/api/*"]
  }
}
